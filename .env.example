# Bexly — AI Personal Financial Coach
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ============================================================
# SUPABASE (Required)
# ============================================================
# Get from Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# ============================================================
# AI — Qwen via vLLM (Primary — self-hosted, on-premise ready)
# ============================================================
# Self-hosted Qwen endpoint via vLLM (OpenAI-compatible API)
BEXLY_FREE_AI_URL=https://your-vllm-server/v1
BEXLY_FREE_AI_KEY=your_api_key_here
BEXLY_FREE_AI_MODEL=dos-ai

# Timeout in seconds — if vLLM doesn't respond, falls back to Gemini
DOS_AI_TIMEOUT=5
DOS_AI_VISION_TIMEOUT=15

# ============================================================
# AI — Fallback providers (Optional, for development only)
# Production should use multiple Qwen instances, not cloud APIs
# ============================================================

# AI provider selector: openai | gemini | custom
AI_PROVIDER=custom

# Google Gemini — fallback for chat + OCR
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — optional fallback for OCR
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude — optional fallback for OCR
CLAUDE_API_KEY=your_claude_api_key_here

# Custom LLM endpoint (alternative to BEXLY_FREE_AI_*)
# CUSTOM_LLM_ENDPOINT=https://your-endpoint/v1
# CUSTOM_LLM_API_KEY=your_key
# CUSTOM_LLM_MODEL=your_model

# ============================================================
# AUTHENTICATION
# ============================================================

# DOS.me OAuth integration
DOSME_API_URL=https://api.dos.me
DOSME_PRODUCT_ID=bexly
USE_DOSME_OAUTH=true

# Google OAuth Android Client IDs (native Google Sign In)
# Get from Google Cloud Console > APIs & Services > Credentials
# Debug and Release need different SHA-1 fingerprints
GOOGLE_ANDROID_CLIENT_ID_DEBUG=your_debug_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID_RELEASE=your_release_client_id.apps.googleusercontent.com

# ============================================================
# PAYMENTS (Optional)
# ============================================================
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
