# Bexly - AI Personal Financial Coach
# Copy this file to .env and fill in your values.
# Build consumes via: flutter build ... --dart-define-from-file=.env
# NEVER commit .env to version control.

# ============================================================
# SUPABASE (Required)
# ============================================================
# Get from Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# ============================================================
# AI — DOS.AI Gateway
# ============================================================
# Auth uses the user's Supabase JWT (no API key in client). The gateway
# at https://api.dos.ai/v1/p/bexly verifies JWT and reads tier from
# public.billing_accounts. Override CUSTOM_LLM_ENDPOINT only for local
# Gateway dev — production builds use the default URL.
#
# CUSTOM_LLM_ENDPOINT=https://api.dos.ai/v1/p/bexly

# Timeout in seconds for DOS AI text + vision requests
DOS_AI_TIMEOUT=5
DOS_AI_VISION_TIMEOUT=30

# Optional: override default model name (gateway routes to upstream)
# BEXLY_FREE_AI_MODEL=dos-ai

# ============================================================
# AUTHENTICATION
# ============================================================

# DOS.me OAuth integration
DOSME_API_URL=https://api.dos.me
DOSME_PRODUCT_ID=bexly
USE_DOSME_OAUTH=true

# Google OAuth Android Client IDs (native Google Sign In)
# Get from Google Cloud Console > APIs & Services > Credentials
# Debug and Release need different SHA-1 fingerprints
GOOGLE_ANDROID_CLIENT_ID_DEBUG=your_debug_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID_RELEASE=your_release_client_id.apps.googleusercontent.com

# ============================================================
# PAYMENTS (Optional)
# ============================================================
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
